<%- include('partials/header') %>

<style>
    /* সাইবারনেটিক অথোরিটি পেজ স্টাইল */
    .auth-page-wrapper {
        background-color: #060b13; 
        color: white;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
        padding-top: 100px;
        padding-bottom: 60px;
        position: relative;
        overflow: hidden;
    }

    /* সাইবার গ্রিড ওভারলে */
    .auth-page-wrapper::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: 
            linear-gradient(rgba(0, 153, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 153, 255, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        z-index: 1;
    }

    /* গ্লোয়িং অথোরিটি কার্ড (গ্লাসমরফিজম ইফেক্ট সহ) */
    .auth-card {
        background: rgba(17, 26, 38, 0.6);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid #1a2638;
        box-shadow: 0 0 30px rgba(0, 153, 255, 0.15);
        padding: 40px;
        border-radius: 20px;
        width: 100%;
        max-width: 480px;
        z-index: 2;
        transition: all 0.3s ease;
    }

    .auth-card:hover {
        border-color: #3399ff;
        box-shadow: 0 0 40px rgba(0, 153, 255, 0.25);
    }

    /* সাইন ইন এবং সাইন আপ সুইচ ট্যাব */
    .auth-tabs {
        display: flex;
        border-bottom: 2px solid #1a2638;
        margin-bottom: 30px;
    }

    .auth-tab-btn {
        flex: 1;
        background: transparent;
        color: #888;
        border: none;
        padding: 15px 0;
        font-family: 'Orbitron', sans-serif;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        text-transform: uppercase;
        transition: 0.3s;
        text-align: center;
    }

    .auth-tab-btn.active, .auth-tab-btn:hover {
        color: #00ffcc;
    }

    .auth-tab-btn.active {
        border-bottom: 3px solid #00ffcc;
        margin-bottom: -2.5px;
    }

    /* ইনপুট ফিল্ড ও বাটনসমূহ */
    .auth-group {
        margin-bottom: 22px;
    }

    .auth-group label {
        display: block;
        color: #aaa;
        font-size: 0.85rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .auth-group input {
        width: 100%;
        background: #060b13;
        border: 1px solid #1a2638;
        padding: 12px 15px;
        color: white;
        border-radius: 8px;
        font-size: 1rem;
        transition: 0.3s;
    }

    .auth-group input:focus {
        border-color: #00ffcc;
        outline: none;
        box-shadow: 0 0 12px rgba(0, 255, 204, 0.2);
    }

    .auth-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
        color: #aaa;
        margin-bottom: 25px;
    }

    .auth-options a {
        color: #3399ff;
        text-decoration: none;
        transition: 0.3s;
    }

    .auth-options a:hover {
        color: #00ffcc;
        text-shadow: 0 0 8px rgba(0, 255, 204, 0.3);
    }

    .btn-auth-submit {
        background: #00ffcc;
        color: #000;
        border: none;
        padding: 14px;
        font-size: 1.1rem;
        font-weight: bold;
        border-radius: 8px;
        cursor: pointer;
        text-transform: uppercase;
        width: 100%;
        font-family: 'Orbitron', sans-serif;
        transition: 0.3s;
        margin-bottom: 20px;
    }

    .btn-auth-submit:hover {
        background: #fff;
        box-shadow: 0 0 20px #00ffcc;
    }

    /* নোটিফিকেশন পপ-আপ (দ্বিমুখী: সাকসেস এবং এরর দুটোই দেখাবে) */
    .neon-popup {
        display: none; 
        position: fixed; 
        top: 100px; 
        right: 30px; 
        background: #111; 
        border: 2px solid #00ffcc; 
        box-shadow: 0 0 15px #00ffcc; 
        padding: 15px 25px; 
        border-radius: 8px; 
        z-index: 1000; 
        transition: opacity 0.5s ease;
        align-items: center; 
        gap: 12px;
        opacity: 0;
    }
</style>

<!-- ১. ফায়ারবেস এসডিকে লোড করা (Compat SDK via CDN) -->
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>

<div class="auth-page-wrapper">
    
    <div class="auth-card">
        <!-- ২. সুইচ ট্যাব -->
        <div class="auth-tabs">
            <button class="auth-tab-btn active" onclick="toggleAuth('signin')">Sign In</button>
            <button class="auth-tab-btn" onclick="toggleAuth('signup')">Sign Up</button>
        </div>

        <!-- ৩. সাইন ইন ফর্ম -->
        <form id="signInForm">
            <div class="auth-group">
                <label>Email Address</label>
                <input type="email" id="loginEmail" required placeholder="john@example.com">
            </div>
            <div class="auth-group">
                <label>Password</label>
                <input type="password" id="loginPassword" required placeholder="••••••••">
            </div>
            <div class="auth-options">
                <label style="cursor: pointer; display: flex; align-items: center; gap: 5px;">
                    <input type="checkbox" style="width: auto; cursor: pointer;"> Remember me
                </label>
                <a href="#">Forgot Password?</a>
            </div>
            <button type="submit" class="btn-auth-submit">Enter Portal</button>
        </form>

        <!-- ৪. সাইন আপ ফর্ম (ডিফল্ট হাইড থাকবে) -->
        <form id="signUpForm" style="display: none;">
            <div class="auth-group">
                <label>Full Name</label>
                <input type="text" id="regName" required placeholder="John Doe">
            </div>
            <div class="auth-group">
                <label>Email Address</label>
                <input type="email" id="regEmail" required placeholder="john@example.com">
            </div>
            <div class="auth-group">
                <label>Create Password (Min 6 Characters)</label>
                <input type="password" id="regPassword" required placeholder="••••••••">
            </div>
            <div class="auth-options">
                <label style="cursor: pointer; display: flex; align-items: center; gap: 5px;">
                    <input type="checkbox" required style="width: auto; cursor: pointer;"> I agree to Terms & Privacy
                </label>
            </div>
            <button type="submit" class="btn-auth-submit">Create Account</button>
        </form>
    </div>

    <!-- ৫. দ্বিমুখী পপ-আপ নোটিফিকেশন -->
    <div id="authPopup" class="neon-popup">
        <span id="popupIcon" style="font-size:1.3rem; font-weight:bold;">✓</span>
        <span id="popupText" style="color:white; font-weight:bold; font-family: 'Orbitron', sans-serif;">Login Successful!</span>
    </div>

</div>

<script>
    // ========================================================
    // ফায়ারবেস ইনিশিয়ালাইজেশন (আপনার আসল কী-গুলো বসানো হয়েছে)
    // ========================================================
    const firebaseConfig = {
        apiKey: "AIzaSyC4l8xo2vKipHcYU4-caawDPN_--2sO6To",
        authDomain: "riverstone-games.firebaseapp.com",
        projectId: "riverstone-games",
        storageBucket: "riverstone-games.firebasestorage.app",
        messagingSenderId: "835809515052",
        appId: "1:835809515052:web:b43d5fc65bba7613676389",
        measurementId: "G-8FW1CXMFV2"
    };

    // ফায়ারবেস চালু করা
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();

    // ========================================================
    // ফর্ম টগল ও পপ-আপ লজিক
    // ========================================================
    function toggleAuth(mode) {
        const signInForm = document.getElementById('signInForm');
        const signUpForm = document.getElementById('signUpForm');
        const tabs = document.querySelectorAll('.auth-tab-btn');

        tabs.forEach(tab => tab.classList.remove('active'));

        if (mode === 'signin') {
            signInForm.style.display = 'block';
            signUpForm.style.display = 'none';
            tabs[0].classList.add('active');
        } else {
            signInForm.style.display = 'none';
            signUpForm.style.display = 'block';
            tabs[1].classList.add('active');
        }
    }

    const authPopup = document.getElementById('authPopup');
    const popupText = document.getElementById('popupText');
    const popupIcon = document.getElementById('popupIcon');

    // সফল হলে সবুজ পপ-আপ
    function triggerSuccessPopup(text) {
        popupText.innerText = text;
        authPopup.style.borderColor = "#00ffcc";
        authPopup.style.boxShadow = "0 0 15px #00ffcc";
        popupIcon.style.color = "#00ffcc";
        popupIcon.innerText = "✓";

        authPopup.style.display = 'flex';
        setTimeout(() => { authPopup.style.opacity = '1'; }, 50);

        setTimeout(() => {
            authPopup.style.opacity = '0';
            setTimeout(() => { authPopup.style.display = 'none'; }, 500);
        }, 3000);
    }

    // ভুল হলে বা এরর দিলে লাল পপ-আপ
    function triggerErrorPopup(text) {
        popupText.innerText = text;
        authPopup.style.borderColor = "#ff3366"; // নেওন রেড
        authPopup.style.boxShadow = "0 0 15px #ff3366";
        popupIcon.style.color = "#ff3366";
        popupIcon.innerText = "✕";

        authPopup.style.display = 'flex';
        setTimeout(() => { authPopup.style.opacity = '1'; }, 50);

        setTimeout(() => {
            authPopup.style.opacity = '0';
            setTimeout(() => { authPopup.style.display = 'none'; }, 500);
        }, 4000);
    }

    // ========================================================
    // রিয়েল-টাইম ফায়ারবেস সাবমিশন প্রসেস
    // ========================================================
    const signInForm = document.getElementById('signInForm');
    const signUpForm = document.getElementById('signUpForm');

    if (signInForm) {
        signInForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const email = signInForm.querySelector('input[type="email"]').value;
            const password = signInForm.querySelector('input[type="password"]').value;

            // ফায়ারবেস লগইন এপিআই
            auth.signInWithEmailAndPassword(email, password)
                .then((userCredential) => {
                    triggerSuccessPopup("Access Granted. Welcome back!");
                    signInForm.reset();
                    // ২ সেকেন্ড পর হোমপেজে রিডাইরেক্ট করবে
                    setTimeout(() => { window.location.href = "/"; }, 2000);
                })
                .catch((error) => {
                    console.error("Error signing in:", error);
                    triggerErrorPopup(error.message);
                });
        });
    }

    if (signUpForm) {
        signUpForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const name = document.getElementById('regName').value;
            const email = document.getElementById('regEmail').value;
            const password = document.getElementById('regPassword').value;

            // ফায়ারবেস রেজিস্ট্রেশন এপিআই
            auth.createUserWithEmailAndPassword(email, password)
                .then((userCredential) => {
                    const user = userCredential.user;
                    // ইউজারের নাম প্রোফাইলে সেট করা
                    return user.updateProfile({ displayName: name });
                })
                .then(() => {
                    triggerSuccessPopup("Account Registered! Please Sign In.");
                    signUpForm.reset();
                    // সাইন-ইন ট্যাবে নিয়ে যাবে
                    setTimeout(() => { toggleAuth('signin'); }, 1500);
                })
                .catch((error) => {
                    console.error("Error signing up:", error);
                    triggerErrorPopup(error.message);
                });
        });
    }
</script>

<%- include('partials/footer') %>