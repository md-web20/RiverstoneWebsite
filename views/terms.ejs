<%- include('partials/header') %>

<style>
    /* গ্লোবাল নেভি-ডার্ক স্পেস থিম */
    .legal-page-wrapper { 
        background-color: #060b13; 
        color: white; 
        min-height: 100vh; 
        padding-bottom: 100px; 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        position: relative;
    }

    /* পিউর সিএসএস সাইবারনেটিক নেভি ব্লু গ্রিড হিরো */
    .legal-hero { 
        height: 45vh; 
        background: 
            radial-gradient(circle at 50% 50%, rgba(0, 153, 255, 0.15), transparent 60%),
            #060b13;
        display: flex; 
        align-items: center; 
        justify-content: center; 
        text-align: center; 
        border-bottom: 2px solid #0099ff; 
        position: relative;
        overflow: hidden;
    }

    /* ইলেকট্রিক ব্লু সাইবার গ্রিড ওভারলে */
    .legal-hero::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: 
            linear-gradient(rgba(0, 153, 255, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 153, 255, 0.04) 1px, transparent 1px);
        background-size: 40px 40px;
        z-index: 1;
    }

    /* গ্লোয়িং ব্যাক বাটন (Back Button) */
    .btn-back-legal {
        position: absolute;
        top: 100px; 
        left: 10%;
        background: transparent;
        color: #3399ff;
        border: 1px solid #1a2638;
        padding: 10px 22px;
        border-radius: 25px;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.9rem;
        font-weight: bold;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        z-index: 10;
        box-shadow: 0 0 10px rgba(0, 153, 255, 0.05);
    }

    .btn-back-legal:hover {
        border-color: #3399ff;
        color: #fff;
        background: rgba(0, 153, 255, 0.1);
        box-shadow: 0 0 15px rgba(0, 153, 255, 0.4);
        transform: translateX(-5px); 
    }

    .legal-title { 
        font-family: 'Orbitron', sans-serif; 
        font-size: 3.5rem; 
        color: #3399ff; 
        margin-top: 80px; 
        text-transform: uppercase; 
        letter-spacing: 2px;
        z-index: 2;
        text-shadow: 0 0 20px rgba(0, 153, 255, 0.6);
    }

    /* কন্টেন্ট লেআউট */
    .legal-content { 
        max-width: 950px; 
        margin: 60px auto 0 auto; 
        padding: 0 5%; 
        line-height: 1.95; 
        color: #ccc; 
    }

    /* হেডলাইনের প্রিমিয়াম ডেকোরেশন */
    .legal-content h2 { 
        color: #fff; 
        font-family: 'Orbitron', sans-serif; 
        font-size: 1.8rem;
        margin-top: 50px; 
        margin-bottom: 25px; 
        border-bottom: 1px solid #1a2638;
        padding-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .section-num {
        color: #3399ff;
        font-size: 1.3rem;
        font-weight: bold;
    }

    .legal-content p { 
        margin-bottom: 25px; 
        text-align: justify; 
        font-size: 1.05rem;
    }

    .sub-section {
        background: #09111c;
        border: 1px solid #1a2638;
        padding: 30px;
        border-radius: 12px;
        margin-bottom: 35px;
        transition: 0.3s;
    }

    .sub-section:hover {
        border-color: #3399ff;
        background: #0d1a2b;
        box-shadow: 0 5px 20px rgba(0, 153, 255, 0.05);
    }

    .sub-section h3 {
        font-family: 'Orbitron', sans-serif;
        color: #3399ff;
        margin-top: 0;
        margin-bottom: 15px;
        font-size: 1.3rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .highlight-text {
        color: #3399ff;
        font-weight: bold;
    }

    .tech-list {
        list-style-type: none;
        padding-left: 0;
    }

    .tech-list li {
        margin-bottom: 15px;
        position: relative;
        padding-left: 25px;
        line-height: 1.7;
    }

    .tech-list li::before {
        content: '✦';
        position: absolute;
        left: 0;
        color: #3399ff;
    }
</style>

