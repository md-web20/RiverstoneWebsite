<%- include('partials/header') %>

<style>
    /* ওয়েব পেজের গ্লোবাল স্টাইল */
    .web-page-wrapper {
        background-color: #0a0a0a;
        color: white;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding-bottom: 60px;
    }

    /* ১. হিরো সেকশন (Featured SaaS/Web) */
    .featured-web-hero {
        position: relative;
        width: 100%;
        height: 80vh;
        display: flex;
        align-items: center;
        padding: 0 10%;
        background-size: cover !important;
        background-position: center top !important;
    }

    .hero-content {
        max-width: 650px;
        z-index: 2;
        margin-top: 80px; /* হেডার বা মেনুবারের জন্য গ্যাপ */
    }

    .badge-featured {
        background-color: #00ffcc;
        color: #000;
        padding: 6px 15px;
        border-radius: 20px;
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        display: inline-block;
    }

    .hero-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
        text-transform: uppercase;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
    }

    .hero-desc {
        font-size: 1.15rem;
        color: #ddd;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .action-buttons {
        display: flex;
        gap: 20px;
    }

    .btn-live {
        background: #00ffcc;
        color: #000;
        padding: 15px 35px;
        font-size: 1.1rem;
        font-weight: bold;
        text-decoration: none;
        border-radius: 8px;
        text-transform: uppercase;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-live:hover {
        background: #fff;
        box-shadow: 0 0 20px #00ffcc;
        transform: translateY(-3px);
    }

    .btn-details {
        background: transparent;
        color: #fff;
        padding: 15px 35px;
        font-size: 1.1rem;
        font-weight: bold;
        text-decoration: none;
        border-radius: 8px;
        border: 2px solid #fff;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }

    .btn-details:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: #00ffcc;
        color: #00ffcc;
    }

    /* ২. ওয়েব প্রজেক্ট গ্রিড সেকশন */
    .web-library {
        padding: 60px 10%;
    }

    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .section-header h2 {
        font-family: 'Orbitron', sans-serif;
        font-size: 2.8rem;
        color: white;
        text-transform: uppercase;
    }
    
    .section-header h2 span {
        color: #00ffcc;
    }

    .web-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 40px;
    }

    .web-card {
        background: #111;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #222;
        transition: all 0.4s ease;
        display: flex;
        flex-direction: column;
        cursor: pointer;
    }

    .web-card:hover {
        transform: translateY(-10px);
        border-color: #00ffcc;
        box-shadow: 0 15px 30px rgba(0, 255, 204, 0.15);
    }

    .card-img-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
    }

    .card-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .web-card:hover .card-img-wrapper img {
        transform: scale(1.05);
    }

    .category-tag {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(0, 0, 0, 0.7);
        color: #00ffcc;
        padding: 5px 12px;
        border-radius: 5px;
        font-size: 0.8rem;
        font-weight: bold;
        border: 1px solid #00ffcc;
        backdrop-filter: blur(5px);
    }

    .card-content {
        padding: 25px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-content h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.5rem;
        margin: 0 0 12px 0;
        color: white;
    }

    .card-content p {
        color: #aaa;
        font-size: 0.95rem;
        line-height: 1.5;
        margin-bottom: 20px;
        flex-grow: 1;
    }

    /* টেকনোলজি ট্যাগের স্টাইল */
    .tech-badges-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
    }

    .tech-badge {
        background: #1c1c1c;
        color: #ccc;
        border: 1px solid #333;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #222;
        padding-top: 15px;
    }

    .visit-link {
        color: #00ffcc;
        text-decoration: none;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: 0.3s;
    }

    .visit-link:hover {
        text-shadow: 0 0 10px #00ffcc;
    }

    @media (max-width: 768px) {
        .hero-title { font-size: 2.5rem; }
        .action-buttons { flex-direction: column; }
        .btn-live, .btn-details { text-align: center; justify-content: center; }
        .featured-web-hero { padding: 0 5%; text-align: center; }
        .hero-content { margin: 80px auto 0 auto; }
        .web-library { padding: 50px 5%; }
    }
</style>

<div class="web-page-wrapper">
    <!-- ১. হিরো সেকশন (ডাইনামিক) -->
    <header id="dynamic-web-hero" class="featured-web-hero">
        <!-- Content injected by JS -->
    </header>

    <!-- ২. ওয়েব ক্যাটালগ সেকশন -->
    <section class="web-library">
        <div class="section-header">
            <h2>Our Web <span style="color: #00ffcc;">Products</span></h2>
            <p style="color: #888; font-size: 1.1rem; margin-top: 10px;">Premium SaaS products, studio websites, and digital interfaces.</p>
        </div>
        
        <!-- গ্রিড (ডাইনামিক) -->
        <div id="dynamic-web-grid" class="web-grid">
            <!-- Cards injected by JS -->
        </div>
    </section>
</div>

<script>
    // ========================================================
    // আপনার ওয়েব প্রজেক্টের ডাটা ব্লক: এখান থেকেই সব কন্ট্রোল করবেন
    // ========================================================
    const webProjectsList = [
        {
            id: 1,
            title: "MemoMama: A Multi - Language Micro-SaaS Business OS",
            shortDesc: "A professional-grade Micro-SaaS designed to bridge the gap between traditional manual bookkeeping and high-end enterprise management systems. Developed with a Privacy-First architecture.",
            thumbnail: "/images/Screenshot_7.png", // আপনার ইমেজের নাম ঠিক করে নেবেন
            category: "Fintech SaaS",
            techStack: ["React.js", "Firebase", "Tailwind CSS", "REST API"],
            liveLink: "https://trymemomama.com", // আসল লিংক এখানে বসাবেন
            isFeatured: true, // "true" দিলে এই প্রজেক্টটি হিরো ব্যানারে বড় করে দেখাবে
            isComingSoon: false
        },
        {
            id: 2,
            title: "Riverstone Studio Site",
            shortDesc: "A futuristic agency website built with high performance, dynamic routes, modern EJS templating, and custom GSAP micro-animations.",
            thumbnail: "/images/coming-soon.png",
            category: "Agency Website",
            techStack: ["Node.js", "Express", "EJS", "CSS Grid"],
            liveLink: "https://riverstonegames.com/",
            isFeatured: false,
            isComingSoon: false
        }
    ];


    function truncateText(str, limit) {
        if (!str) return "";
        if (str.length > limit) {
            return str.substring(0, limit) + "...";
        }
        return str;
    }

    // ========================================================
    // ডাটা রেন্ডার করার লজিক
    // ========================================================
    
    // ১. ওয়েব হিরো রেন্ডার করা
    function renderWebHero() {
        const heroSection = document.getElementById('dynamic-web-hero');
        const featuredProject = webProjectsList.find(p => p.isFeatured === true) || webProjectsList[0]; 

        heroSection.style.background = `linear-gradient(to top, #0a0a0a 0%, transparent 100%), linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 100%), url('${featuredProject.thumbnail}')`;

        // এখানে truncateText() ব্যবহার করে টাইটেলটি ৩০ ক্যারেক্টারে সীমাবদ্ধ করা হয়েছে
        const truncatedTitle = truncateText(featuredProject.title, 30);

        heroSection.innerHTML = `
            <div class="hero-content">
                <span class="badge-featured">Featured Product</span>
                <h1 class="hero-title">${truncatedTitle}</h1>
                <p class="hero-desc">${featuredProject.shortDesc}</p>
                <div class="action-buttons">
                    <a href="${featuredProject.liveLink}" target="_blank" class="btn-live">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        Launch App
                    </a>
                    <a href="/portfolio" class="btn-details">Case Study</a>
                </div>
            </div>
        `;
    }

    // ২. ওয়েব গ্রিড রেন্ডার করা
    function renderWebGrid() {
        const gridContainer = document.getElementById('dynamic-web-grid');
        gridContainer.innerHTML = ""; 

        webProjectsList.forEach(project => {
            const opacityStyle = project.isComingSoon ? 'style="opacity: 0.7;"' : '';
            const imgStyle = project.isComingSoon ? 'style="filter: grayscale(100%);"' : '';
            const tagStyle = project.isComingSoon ? 'style="background: #333; color: white; border-color: #555;"' : '';
            const linkStyle = project.isComingSoon ? 'style="color: #aaa;"' : '';
            
            const finalLink = project.isComingSoon ? '#' : project.liveLink;
            const playText = project.isComingSoon ? 'Coming Soon' : 'Launch Site ➔';

            // এখানেও সেফটি হিসেবে নিচের কার্ডের টাইটেল ২৫ ক্যারেক্টারে সীমাবদ্ধ করা হয়েছে
            const truncatedCardTitle = truncateText(project.title, 25);

            // টেকনোলজি ব্যাজ তৈরি করা
            const techBadgesHTML = project.techStack.map(tech => `<span class="tech-badge">${tech}</span>`).join('');

            gridContainer.innerHTML += `
                <div class="web-card" ${opacityStyle}>
                    <div class="card-img-wrapper">
                        <span class="category-tag" ${tagStyle}>${project.category}</span>
                        <img src="${project.thumbnail}" alt="${project.title}" ${imgStyle}>
                    </div>
                    <div class="card-content">
                        <h3>${truncatedCardTitle}</h3>
                        <p>${project.shortDesc}</p>
                        
                        <!-- টেকনোলজি ব্যাজ লিস্ট -->
                        <div class="tech-badges-list">
                            ${techBadgesHTML}
                        </div>

                        <div class="card-footer">
                            <span style="color: #666; font-size: 0.85rem; font-weight: bold;">Web Application</span>
                            <a href="${finalLink}" target="_blank" class="visit-link" ${linkStyle}>${playText}</a>
                        </div>
                    </div>
                </div>
            `;
        });
    }

    renderWebHero();
    renderWebGrid();
</script>

<%- include('partials/footer') %>