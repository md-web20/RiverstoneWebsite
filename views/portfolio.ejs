<%- include('partials/header') %>

<section class="portfolio-section">
    <h1 id="portfolio-title" class="section-title" style="font-size: 4rem; letter-spacing: 10px;">OUR WORK</h1>
    <p style="color: #94a3b8; max-width: 600px; margin: 0 auto 50px;">A showcase of precision, performance, and futuristic digital craftsmanship.</p>

    <div class="portfolio-grid" id="project-list">
        <!-- কার্ডগুলো এখানে লোড হবে -->
    </div>
</section>

<!-- প্রজেক্ট ডিটেইল পপ-আপ (Modal) -->
<div id="projectModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <div id="modal-body">
            <!-- ডাটা এখানে ডাইনামিকভাবে আসবে -->
        </div>
    </div>
</div>


<!-- ৩. JavaScript অংশ: যেটা কার্ড তৈরি করবে -->
