        font-family: 'Orbitron', sans-serif;
        font-size: 1.1rem;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .footer-links ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: 12px;
    }

    .footer-links a {
        color: #888;
        text-decoration: none;
        transition: 0.3s ease;
        font-size: 0.95rem;
    }

    /* হোভার করলে আলতো করে স্লাইড হবে এবং নেওন গ্লো দেখাবে */
    .footer-links a:hover {
        color: #00ffcc;
        text-shadow: 0 0 8px rgba(0, 255, 204, 0.4);
        padding-left: 6px; 
    }

    /* ফুটারের একদম নিচের কপিরাইট ও সোশ্যাল স্ট্রিপ */
    .footer-bottom {
        max-width: 1440px;
        width: 100%;
        margin: 50px auto 0 auto;
        padding: 25px 30px 0 30px;
        border-top: 1px solid #111;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        box-sizing: border-box;
    }

    .footer-socials {
        display: flex;
        gap: 15px;
        flex-wrap: wrap; /* এই লাইনটি মোবাইল স্ক্রিনে অনেকগুলো লিংক থাকলে ভেঙে সুন্দর লাইন তৈরি করবে */
        justify-content: flex-end;
    }

    .footer-socials a {
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.3s ease;
    }

    .footer-socials a:hover {
        color: #00ffcc;
        text-shadow: 0 0 8px rgba(0, 255, 204, 0.4);
    }

    /* মোবাইল ও ট্যাবলেট রেসপন্সিভ */
    @media (max-width: 992px) {
        .footer-container {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 35px;
        }
        .footer-about p {
            text-align: center;
        }
        .footer-logo {
            justify-content: center;
        }
        .footer-links li a:hover {
            padding-left: 0; /* মোবাইলে স্লাইড বন্ধ থাকবে */
        }
        .footer-bottom {
            flex-direction: column;
            gap: 18px;
            text-align: center;
            padding-top: 20px;
        }
        .footer-socials {
            justify-content: center;
            gap: 12px;
        }
    }
</style>

