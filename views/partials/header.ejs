<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- মেনুবার মাঝখানে গুছিয়ে রাখার জন্য কাস্টম সিএসএস -->
    <!-- মেনুবার স্লিম ও মাঝখানে গুছিয়ে রাখার জন্য কাস্টম সিএসএস -->
    <style>
        nav {
            width: 100%;
            background-color: #000000;
            border-bottom: 2px solid #00ffcc;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
        }
        
        .nav-container {
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 30px; /* ওপরের ও নিচের প্যাডিং ১৫px থেকে কমিয়ে ৮px করা হলো */
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 25px;
            margin: 0;
            padding: 0;
            align-items: center;
        }

        body {
            padding-top: 65px; /* মেনুবার স্লিম হওয়ায় বডির টপ মার্জিনও ৮০px থেকে কমিয়ে ৬৫px করা হলো */
        }
    </style>
</head>
<body>
    <nav>
        <!-- মেইন কন্টেইনার যুক্ত করা হয়েছে -->
        <div class="nav-container">
            <div class="logo">
                <img src="/images/favicon.png" alt="Logo">
                <span id="nav-brand" class="nav-brand">RIVERSTONE GAMES</span>
            </div>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/games">Games</a></li>
                <li><a href="/web">Web</a></li>
                <li><a href="/apps">Apps</a></li>
                <li><a href="/portfolio">Portfolio</a></li>
                <li><a href="/contact">Contact</a></li>
                <!-- আপনার আসল সাইন-ইন বাটন ক্লাসটি এখানে ব্যবহার করুন -->
                <li><a href="/signin" class="signin-btn">Sign In</a></li>
            </ul>
        </div>
    </nav>